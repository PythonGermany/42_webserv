all:
	c++ -std=c++98 -Wall -Wextra -Werror -Wpedantic main.cpp ListenSocket.cpp Poll.cpp AConnection.cpp ClientSocket.cpp ../src/poll/Address.cpp -I../include/poll/

debug:
	c++ -std=c++98 -Wall -Wextra -Werror -Wpedantic  -g main.cpp ListenSocket.cpp Poll.cpp AConnection.cpp ClientSocket.cpp ../src/poll/Address.cpp -I../include/poll/